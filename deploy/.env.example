# Required – issued in the Radio Core admin UI
RADIO_CORE_API_URL=https://core.your-radio.com
RADIO_CORE_STATION_SLUG=my-station
RADIO_CORE_STACK_TOKEN=replace-me

# Optional
TZ=Europe/Stockholm
ICECAST_PORT=8000
POLL_INTERVAL_SECONDS=30
HEALTH_INTERVAL_SECONDS=60

# Path on the host that contains a licensed Thimeo Stereo Tool binary + presets.
# Leave as-is if you don't use Stereo Tool – an empty ./stereo-tool folder is fine.
STEREO_TOOL_DIR=./stereo-tool
