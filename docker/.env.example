# Docker Compose lokal dev-miljö
# Kopiera till docker/.env: cp docker/.env.example docker/.env

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=radiocore
POSTGRES_USER=radiocore
POSTGRES_PASSWORD=radiocore

# ─── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@radio-core.local
PGADMIN_PASSWORD=localdev
