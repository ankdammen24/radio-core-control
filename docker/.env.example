# Docker Compose local development environment
# Copy to docker/.env before running: cp docker/.env.example docker/.env

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=radio_core
POSTGRES_USER=radio_core
POSTGRES_PASSWORD=localdev

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@radio-core.local
PGADMIN_PASSWORD=localdev
