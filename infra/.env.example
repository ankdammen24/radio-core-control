# Radio Core — Infrastruktur-miljövariabler
# Kopiera till infra/.env: cp infra/.env.example infra/.env
# Committa ALDRIG infra/.env till git.

# ─── Miljö ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Domäner ────────────────────────────────────────────────────────────────────
DOMAIN=radiouppsala.se
API_DOMAIN=api.radiouppsala.se
STUDIO_DOMAIN=studio.radiouppsala.se
STREAM_DOMAIN=stream.radiouppsala.se
PODCAST_DOMAIN=podcast.radiouppsala.se

# ─── PostgreSQL (Drizzle ORM) ────────────────────────────────────────────────────
# Lokal dev (Docker):
DATABASE_URL=postgres://radiocore:radiocore@postgres:5432/radiocore
# Produktion (Neon eller extern):
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
POSTGRES_DB=radiocore
POSTGRES_USER=radiocore
POSTGRES_PASSWORD=radiocore

# ─── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_ROOT_USER=root
MONGODB_ROOT_PASSWORD=changeme
MONGODB_USER=radio
MONGODB_PASSWORD=radio
MONGODB_DB=radiocore
# MONGODB_URL sätts automatiskt av compose från ovan

# Sätt till befintligt Supabase station-id under övergången så read/write-ID:n matchar.
RADIO_UPPSALA_STATION_ID=7b5fd114-b188-4d8d-9210-3e924c68efc7

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_MAX_MEMORY=256mb
REDIS_PASSWORD=
# Lämna REDIS_PASSWORD tomt i dev. Sätt i produktion.

# ─── pgAdmin (dev only) ──────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@radio-core.local
PGADMIN_PASSWORD=localdev

# ─── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generera: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl
JWT_SECRET=change-me-generate-with-openssl

# ─── Cloudflare R2 / Media ──────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=radio-core-media
R2_PUBLIC_BASE_URL=https://media.radiouppsala.se

S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_MEDIA=radio-core-media
S3_BUCKET_ARTWORK=radio-core-artwork
S3_BUCKET_PUBLIC=radio-core-public

# ─── Mail (SMTP) ────────────────────────────────────────────────────────────────
MAIL_URL=smtp://localhost:1025
MAIL_FROM=noreply@radiouppsala.se
# Produktion: smtp://apikey:re_xxx@smtp.resend.com:587

# ─── Cron / Webhooks ─────────────────────────────────────────────────────────────
# Generera: openssl rand -hex 32
CRON_SECRET=change-me

# ─── Secrets (API-nycklar för tjänster) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
