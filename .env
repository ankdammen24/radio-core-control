# Radio Core — Lokala miljövariabler
# Genereras från .env.example — committa ALDRIG den här filen.

# ─── Media / R2 ─────────────────────────────────────────────────────────────────
ARTWORK_PUBLIC_URL=https://img.radiouppsala.se
MEDIA_PUBLIC_URL=https://media.radiouppsala.se
PUBLIC_CDN_URL=https://cdn.radiouppsala.se

S3_ENDPOINT=https://1bfa26f7fd6599043c61391e142bc748.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_MEDIA=radio-core-media
S3_BUCKET_ARTWORK=radio-core-artwork
S3_BUCKET_PUBLIC=radio-core-public

# ─── Database (Drizzle + PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgres://radiocore:radiocore@localhost:5432/radiocore

# ─── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/radiocore

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────────────────────────────
AUTH_SECRET=dev-secret-change-me
JWT_SECRET=dev-jwt-secret-change-me

# ─── Frontend → Backend ──────────────────────────────────────────────────────────
# Tom i dev (relativa anrop via TanStack Start). I prod: https://api.radiouppsala.se
VITE_API_URL=
