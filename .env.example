# Radio Core — Environment Variables
# Copy to .env: cp .env.example .env
# Never commit .env to git.

# ─── Application ───────────────────────────────────────────────────────────────
# Public URL of the Radio Core web app (used in Liquidsoap config etc.)
APP_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000

# ─── Database (PostgreSQL via Drizzle ORM) ────────────────────────────────────
# Local dev (Docker Compose): use this
DATABASE_URL=postgresql://radio_core:localdev@localhost:5432/radio_core

# Production (Neon): replace with your Neon connection string
# DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/radio_core?sslmode=require

# During Supabase transition: use the Supabase direct connection string
# DATABASE_URL=postgresql://postgres.PROJECTID:PASSWORD@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev (Docker Compose):
REDIS_URL=redis://localhost:6379

# Production:
# REDIS_URL=rediss://user:password@hostname:6380

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
# Local dev (Mailpit): http://localhost:8025
MAIL_URL=smtp://localhost:1025
MAIL_FROM=noreply@radio-core.local

# Production (e.g. Resend, Postmark, SES):
# MAIL_URL=smtp://apikey:re_xxx@smtp.resend.com:587

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# ─── OAuth (Google) ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth (Apple) ────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# S3-compatible endpoint (keep as-is for R2)
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bucket names
S3_BUCKET_MEDIA=radio-core-media
S3_BUCKET_ARTWORK=radio-core-artwork
S3_BUCKET_PUBLIC=radio-core-public

# Public CDN URLs (Cloudflare-fronted)
MEDIA_PUBLIC_URL=https://media.example.com
ARTWORK_PUBLIC_URL=https://img.example.com
PUBLIC_CDN_URL=https://cdn.example.com

# ─── Supabase (legacy — remove after migration) ────────────────────────────────
# These will be removed once the Supabase→PostgreSQL migration is complete.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret used by Vercel Cron (or GitHub Actions) to call /api/public/cron/*
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me
