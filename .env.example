# Radio Core — Environment Variables
# Kopiera till .env: cp .env.example .env
# Committa ALDRIG .env till git.

# ─── Application ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000

# ─── Database (PostgreSQL via Drizzle ORM) ──────────────────────────────────────
# Lokal dev (Docker Compose):
DATABASE_URL=postgres://radiocore:radiocore@localhost:5432/radiocore

# Produktion (Neon):
# DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/radiocore?sslmode=require

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Produktion:
# REDIS_URL=rediss://user:password@hostname:6380

# ─── Mail (SMTP) ────────────────────────────────────────────────────────────────
# Lokal dev (Mailpit): http://localhost:8025
MAIL_URL=smtp://localhost:1025
MAIL_FROM=noreply@radio-core.local

# Produktion (t.ex. Resend, Postmark, SES):
# MAIL_URL=smtp://apikey:re_xxx@smtp.resend.com:587

# ─── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generera med: openssl rand -base64 32
AUTH_SECRET=dev-secret-change-me
JWT_SECRET=dev-jwt-secret-change-me

# ─── OAuth (Google) ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth (Apple) ──────────────────────────────────────────────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_BUCKET=radio-core-media
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_BASE_URL=https://media.example.com

# S3-kompatibel endpoint (behåll som-är för R2)
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_MEDIA=radio-core-media
S3_BUCKET_ARTWORK=radio-core-artwork
S3_BUCKET_PUBLIC=radio-core-public

# Publika CDN-URL:er (Cloudflare-frontade)
MEDIA_PUBLIC_URL=https://media.example.com
ARTWORK_PUBLIC_URL=https://img.example.com
PUBLIC_CDN_URL=https://cdn.example.com

# ─── Cron ───────────────────────────────────────────────────────────────────────
# Hemlighet för Vercel Cron (eller GitHub Actions) att anropa /api/public/cron/*
# Generera med: openssl rand -hex 32
CRON_SECRET=change-me

# ─── AzuraCast (legacy — behålls tills AzuraCast-integration är migrerad) ───────
# AZURACAST_URL=https://your-azuracast.example.com
# AZURACAST_API_KEY=your-api-key

# ─── Vercel frontend ──────────────────────────────────────────────────────────
# Enda obligatoriska frontendvariabeln.
VITE_API_URL=https://api.radiouppsala.se

# Explicit opt-in för lokal admin-bootstrap. Lämna false i normal produktion.
VITE_ENABLE_LOCAL_AUTH=false

# Valfri Supabase legacy-integration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Valfri server-side Supabase-åtkomst under migrationen.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
